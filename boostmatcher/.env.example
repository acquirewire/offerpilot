# Copy to .env (same folder you run `python -m boostmatcher` from) and fill in.
# boostmatcher auto-loads .env on every command.

# --- Betfair (DO THIS FIRST: delayed app key is free + self-serve) ---
# developer.betfair.com -> create app -> use the free DELAYED app key.
BETFAIR_APP_KEY=
# Username + password are enough for `betfair-login` (interactive, no cert):
#   python -m boostmatcher betfair-login   -> prints BETFAIR_SESSION_TOKEN=...
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
# Filled by betfair-login (or paste one you obtained yourself):
BETFAIR_SESSION_TOKEN=
# Only needed for `betfair-login --method cert` (the robust always-on path):
BETFAIR_CERT_FILE=client-2048.crt
BETFAIR_KEY_FILE=client-2048.key

# --- Smarkets (OPTIONAL, LATER: lower 2% commission but NOT free) ---
# NOT self-serve: needs a verified account + a one-off £150 admin fee + an API
# Request Form that Smarkets approve manually. Skip unless you want the 2% rate.
SMARKETS_API_TOKEN=

# --- Alerts (already used by your jobtracker/Fatsoma bots) ---
NTFY_SERVER=https://ntfy.sh
# ntfy_topic is set in config.yaml, not here.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
