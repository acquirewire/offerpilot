# ---- Twilio (SMS) ----
# Console: https://console.twilio.com  (Account SID + Auth Token on the dashboard)
# Buy/verify a sending number under Phone Numbers.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+447700900000
ALERT_SMS_TO=+447700900111            # comma-separated for multiple recipients

# ---- Email ----
# Pick ONE backend. SendGrid is simplest; SMTP works with Gmail app passwords.
EMAIL_BACKEND=smtp                     # "smtp" or "sendgrid"
ALERT_EMAIL_TO=you@example.com         # comma-separated for multiple recipients
ALERT_EMAIL_FROM=alerts@example.com

# SendGrid (if EMAIL_BACKEND=sendgrid): https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxx

# SMTP (if EMAIL_BACKEND=smtp). For Gmail create an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password

# ---- Proxies (optional) ----
# Comma-separated list. Rotated round-robin. Leave blank to go direct.
# Format: http://user:pass@host:port
PROXIES=
